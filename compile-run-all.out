f: src/vec-any-type-enum.rs


     1	#[derive(Debug)]
     2	enum Mixed {
     3	    Int(i32),
     4	    Text(String),
     5	    Float(f64),
     6	}
     7	
     8	fn main() {
     9	    // A vector that can hold any of the variants defined in the Mixed enum
    10	    let list: Vec<Mixed> = vec![
    11	        Mixed::Int(42),
    12	        Mixed::Text("Hello Rust".to_string()),
    13	        Mixed::Float(3.14),
    14	    ];
    15	
    16	    for item in list {
    17	        match item {
    18	            Mixed::Int(i) => println!("\nInteger: {i}"),
    19	            Mixed::Text(s) => println!("\nText: {s}"),
    20	            Mixed::Float(f) => println!("\nFloat: {f}"),
    21	        }
    22	    }
    23	}



Integer: 42

Text: Hello Rust

Float: 3.14

f: src/vec-any-type-trait.rs


     1	trait Speaker {
     2	    fn speak(&self);
     3	}
     4	
     5	struct Dog;
     6	impl Speaker for Dog {
     7	    fn speak(&self) { println!("\nWoof!"); }
     8	}
     9	
    10	struct Cat;
    11	impl Speaker for Cat {
    12	    fn speak(&self) { println!("\nMeow!"); }
    13	}
    14	
    15	fn main() {
    16	    // Box<dyn Speaker> allows the vector to store any type implementing Speaker
    17	    let critters: Vec<Box<dyn Speaker>> = vec![
    18	        Box::new(Dog),
    19	        Box::new(Cat),
    20	    ];
    21	
    22	    for critter in critters {
    23	        critter.speak();
    24	    }
    25	}



Woof!

Meow!

f: src/vec-same-type.rs


     1	fn main() {
     2	    // Creating vectors - the macro is convenient for literals
     3	    let numbers = vec![1, 2, 3, 4, 5];
     4	
     5	    // Or create an empty one and build it up
     6	    let mut names: Vec<String> = Vec::new();
     7	    names.push(String::from("Alice"));
     8	    names.push(String::from("Bob"));
     9	
    10	    // Access elements - panics if out of bounds
    11	    let first = numbers[0];
    12	    println!("\n\tfirst: {}", first);
    13	
    14	    // Safe access that returns Option<&T>
    15	    for n in 0..=9 {
    16	        match numbers.get(n) {
    17	            Some(n) => println!("\tFound: {}", n),
    18	            None => println!("\tIndex out of bounds"),
    19	        }
    20	    }
    21	}



	first: 1
	Found: 1
	Found: 2
	Found: 3
	Found: 4
	Found: 5
	Index out of bounds
